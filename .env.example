# .env 템플릿 — 복사해서 사용: cp .env.example .env
# .env는 깃에 올라가지 않으므로 (.gitignore 등록됨) 시크릿은 .env에만 적을 것.

# 서버-워커 공유 시크릿. EC2와 홈 PC 양쪽에서 같은 값이어야 한다.
# 운영 시에는 길고 추측 불가능한 문자열로 변경할 것.
WORKER_TOKEN=dev

# 워커가 바라볼 서버 주소 (워커 전용, 기본값 http://localhost:5000)
#EC2_URL=http://<EC2-주소>:5000

# 서버 포트 (기본값 5000)
#PORT=5000
