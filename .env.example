# .env 템플릿 — 복사해서 사용: cp .env.example .env
# .env는 깃에 올라가지 않으므로 (.gitignore 등록됨) 시크릿은 .env에만 적을 것.

# 서버-워커 공유 시크릿. EC2와 홈 PC 양쪽에서 같은 값이어야 한다.
# 운영 시에는 길고 추측 불가능한 문자열로 변경할 것.
WORKER_TOKEN=dev

# 워커가 바라볼 서버 주소 (워커 전용, 기본값 http://localhost:5000)
#EC2_URL=http://<EC2-주소>:5000

# 서버 포트 (기본값 5000)
#PORT=5000

# ── 이하 EC2 서버 전용 (nginx + HTTPS 운영 시 — setup-nginx.sh 참고) ──

# 웹 UI 접속 비밀번호. 비워두면 인증 없이 열림 (로컬 개발용).
#WEB_PASSWORD=

# 세션 쿠키 서명 키: openssl rand -hex 32 로 생성.
# 미설정 시 서버 재시작마다 브라우저 재로그인이 필요하다.
#SECRET_KEY=

# 오디오 파일 서빙을 nginx에 위임 (X-Accel-Redirect). setup-nginx.sh 적용 시 1.
#NGINX_ACCEL=1

# gunicorn 바인드 주소 (기본값 0.0.0.0). nginx 뒤에서는 127.0.0.1로 제한.
#BIND=127.0.0.1
